ISSUER=https://auth.example.com
OIDC_CLIENT_ID=openai-sso
OIDC_CLIENT_SECRET=replace-with-client-secret
ALLOWED_REDIRECT_URIS=https://external.auth.openai.com/sso/oidc/your-connection/callback
ACCOUNT_DOMAIN=example.com
OPENAI_LOGIN_URL=https://chatgpt.com/auth/login?sso=true&connection=conn_replace
AUTHORIZATION_CODE_TTL_SECONDS=300
TOKEN_TTL_SECONDS=3600
TURNSTILE_SITE_KEY=0x4AAAAA...
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
PRIVATE_JWK={"kty":"RSA","kid":"replace-with-key-id","alg":"RS256","use":"sig"}
ADMIN_TOKEN=replace-with-admin-token
